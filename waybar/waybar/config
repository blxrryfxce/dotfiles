{
  "layer": "top",
  "position": "top",
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["network", "pulseaudio", "bluetooth", "temperature", "custom/cpu", "memory", "custom/battery"],

  "hyprland/workspaces": {
    "format": "[{name}]",
    "disable-scroll": false,
    "tooltip": true,
    "interval": 1
  },

  "custom/cpu": {
    "exec": "~/.config/scripts/waybar/cpuHistory.sh",
    "interval": 1,
    "format": "[{text}]",
    "tooltip": true,
    "return-type": "json"
  },

  "memory": {
    "format": "[Ņ┐ģ {used}/{total}GB]",
    "tooltip": true,
    "interval": 2
  },

  "temperature": {
    "input-filename": "temp1_input",
    "warning-threshold": 70,
    "critical-threshold": 85,
    "format-icons": ["’ŗŗ"],
    "format": "[’ŗŗ {temperatureC}┬░C]",
    "format-warning": "[’ŗē Ņ®¼ {temperatureC}┬░C]",
    "format-critical": "[’ŗć ¾▒ŚŚ {temperatureC}┬░C]",
    "tooltip-format": "[{temperatureC}┬░C {temperatureK}K {temperatureF}┬░F]",
    "interval": 4
  },

  "network": {
    "interface": "wlan0",
    "format": "[{ifname}]",
    "format-wifi": "[’ć½]",
    "format-ethernet": "[’āü]",
    "format-disconnected": "",
    "format-disconnected": "[’ü▓]",
    "tooltip-format": "[{ifname}]",
    "tooltip-format-wifi": "[{essid} ({signalStrength}%) ’ć½]",
    "tooltip-format-ethernet": "[{ifname} ’āü]",
    "tooltip-format-disconnected": "[Disconnected]",
    "max-length": 50,
    "on-click": "nmgui"
  },

  "custom/battery": {
    "exec": "~/.config/scripts/waybar/battery.sh",
    "interval": 1
  },

  "clock": {
    "format": "[{:%H:%M} ’ĆŚ]",
    "format-alt": "{:%A, %B %d, %Y (%R)} ’ü│",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode"          : "year",
      "mode-mon-col"  : 3,
      "weeks-pos"     : "right",
      "on-scroll"     : 1,
      "on-click-right": "mode",
      "format": {
        "months":     "<span color='#000000'><b>{}</b></span>",
        "weeks":      "<span color='#1a1a1a'><b>W{}</b></span>",
        "weekdays":   "<span color='#2b2b2b'><b>{}</b></span>",
        "days":       "<span color='#404040'><b>{}</b></span>",
        "today":      "<span color='#000000'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },

  "pulseaudio": {
    "format": "[{icon} {volume}%]",
    "format-muted": "’æ”",
    "format-icons": {
      "alsa_output.pci-0000_00_1f.3.analog-stereo": "ŅīŁ",
      "alsa_output.pci-0000_00_1f.3.analog-stereo-muted": "Ņ╗©ŅīŁ",
      "default": ["’Ć¦", "’Ć©"]
    },
    "tooltip-format": "Volume mixer",
    "scroll-step": 1,
    "on-click": "pavucontrol"
  },

  "bluetooth": {
    // "controller": "controller1", // specify the alias of the controller if there are more than 1 on the system
    "format": "[’Ŗö]",
    "format-disabled": "[¾░é▓]", // an empty format will hide the module
    "format-connected": "[’Ŗö]",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "blueman-manager"
  },
}